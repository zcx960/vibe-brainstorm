# Copy to .env and fill in at least ONE provider API key.
#   cp .env.example .env

# ---- App ----
# NOTE: keep comments on their OWN line. docker compose's env_file treats
# everything after '=' as the value, so an inline comment becomes part of it.
# host port for the web UI  ->  http://localhost:<APP_PORT>
APP_PORT=8080
# host port mapped to Postgres (for local psql)
DB_PORT=5432

# ---- Postgres ----
POSTGRES_USER=brainstorm
POSTGRES_PASSWORD=change-me-before-deploy
POSTGRES_DB=brainstorm

# ---- LLM provider API keys (fill at least one) ----
# Each maps to a provider defined in backend/providers.yaml.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# 通义千问 (Alibaba DashScope, OpenAI-compatible mode)
DASHSCOPE_API_KEY=
# 智谱 GLM
ZHIPU_API_KEY=
# Kimi / Moonshot
MOONSHOT_API_KEY=
# local Ollama ignores the key, any placeholder works
OLLAMA_API_KEY=ollama

# ---- Defaults for new expansions (must match providers.yaml ids) ----
DEFAULT_PROVIDER=deepseek
DEFAULT_MODEL=deepseek-chat

# ---- Auth (multi-user collaboration) ----
# CHANGE THIS in production — it signs all login tokens.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_DAYS=7
# Admin panel password (visit http://localhost:8080/admin). Defaults to admin123 if unset.
ADMIN_PASSWORD=change-me-before-deploy
